# Copy to .env and fill in. The LLM demo reads from .env automatically.

# Optional: Google Gemini API key for the spec-generation demo.
# Without it, the demo falls back to a deterministic fixture so it always runs.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: alternate name we also accept
# GOOGLE_API_KEY=

# Fallback provider: Groq (used automatically if Gemini rate-limits or fails).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
